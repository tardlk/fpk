#!/bin/bash

LOG_FILE="${TRIM_PKGVAR}/${TRIM_APPNAME}.log"
PID_FILE="${TRIM_PKGVAR}/${TRIM_APPNAME}.pid"

APP_DIR="${TRIM_APPDEST}"
APP_DATA_DIR="${TRIM_PKGVAR}"

SERVICE_COMMAND="$APP_DIR/bin/alist-server $APP_DATA_DIR"
SVC_BACKGROUND=y
SVC_WRITE_PID=y

service_preuninst() {
    # 兜底：确保 alist 进程被完全终止
    # 使用 -x 精确匹配进程名，避免误杀 appcenter-cli 等包含 "alist" 参数的进程
    pkill -x "alist" 2>/dev/null || true
    sleep 1
    pkill -9 -x "alist" 2>/dev/null || true
}

service_poststop() {
    service_preuninst
}

# First install: init config + set admin credentials from wizard
service_postinst() {
    if [ -z "${wizard_username:-}" ] && [ -z "${wizard_password:-}" ]; then
        return 0
    fi

    CONFIG_FILE="$APP_DATA_DIR/data/config.json"
    if [ -f "$CONFIG_FILE" ] && grep -q "__TRIM_SERVICE_PORT__" "$CONFIG_FILE"; then
        JWT_SECRET="$(head -c 32 /dev/urandom | base64 | tr -d '\n' | tr -d '+/' | head -c 32)"
        sed -i "s|__TRIM_SERVICE_PORT__|${TRIM_SERVICE_PORT:-5246}|g; s|__JWT_SECRET__|${JWT_SECRET}|g" "$CONFIG_FILE"
    fi

    cd "$APP_DIR" || return
    ./alist server --data "$APP_DATA_DIR/data" > /dev/null 2>&1 &
    ALIST_PID=$!
    sleep 2

    ALIST_USER="${wizard_username:-admin}"
    ALIST_PASS="${wizard_password}"
    if [ -n "$ALIST_PASS" ]; then
        ln -sf "$APP_DATA_DIR/data" data
        ./alist admin set "$ALIST_USER" "$ALIST_PASS"
        rm -f data
    fi

    kill "$ALIST_PID" 2>/dev/null
    wait "$ALIST_PID" 2>/dev/null
    sleep 1
}
