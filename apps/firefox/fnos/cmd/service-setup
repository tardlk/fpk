#!/bin/bash

service_postinst() {
    mkdir -p "${TRIM_PKGVAR}/config" 2>/dev/null || true
    mkdir -p "${TRIM_PKGVAR}/fonts" 2>/dev/null || true
    apply_mirror "${wizard_docker_mirror:-}"
}

COMPOSE_FILE="${TRIM_APPDEST}/docker/docker-compose.yaml"
PORT_SAVE="${TRIM_PKGVAR}/.port"
MIRROR_SAVE="${TRIM_PKGVAR}/.mirror"

apply_port() {
    local port="$1"
    [ -z "$port" ] && return
    sed -i 's/"[^"]*:5800"/"'"${port}"':5800"/' "$COMPOSE_FILE"
    echo "${port}" > "$PORT_SAVE"
    install_log "Patched docker-compose.yaml: port=${port}"
}

apply_mirror() {
    local mirror="${1:-}"
    # Normalize: strip https?://, ensure trailing /
    mirror=$(echo "$mirror" | sed 's|^https\?://||; s|/*$|/|')
    # Empty after normalization -> use docker.io/
    [ "$mirror" = "/" ] && mirror="docker.io/"
    sed -i "s|__DOCKER_MIRROR__|${mirror}|g" "$COMPOSE_FILE"
    echo "${mirror}" > "$MIRROR_SAVE"
    install_log "Patched docker-compose.yaml: mirror=${mirror}"
}

service_postupgrade() {
    if [ -f "$PORT_SAVE" ]; then
        apply_port "$(cat "$PORT_SAVE")"
    fi
    if [ -f "$MIRROR_SAVE" ]; then
        apply_mirror "$(cat "$MIRROR_SAVE")"
    fi
}

service_postconfig() {
    if [ -n "${wizard_port:-}" ]; then
        apply_port "${wizard_port}"
    fi
    if [ -n "${wizard_docker_mirror:-}" ]; then
        apply_mirror "${wizard_docker_mirror}"
    fi
}
