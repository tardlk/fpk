#!/bin/bash

LOG_FILE="${TRIM_PKGVAR}/${TRIM_APPNAME}.log"
PID_FILE="${TRIM_PKGVAR}/${TRIM_APPNAME}.pid"

APP_DIR="${TRIM_APPDEST}"
APP_DATA_DIR="${TRIM_PKGVAR}"

SERVICE_COMMAND="$APP_DIR/openlist server --data $APP_DATA_DIR"
SVC_BACKGROUND=y
SVC_WRITE_PID=y

service_preuninst() {
    # 兜底：确保 openlist 进程被完全终止
    # 使用 -x 精确匹配进程名，避免误杀 appcenter-cli 等包含 "openlist" 参数的进程
    pkill -x "openlist" 2>/dev/null || true
    sleep 1
    pkill -9 -x "openlist" 2>/dev/null || true
}

service_poststop() {
    service_preuninst
}
